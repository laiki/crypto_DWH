flowchart TB
    classDef src fill:#e8f4ff,stroke:#1f78b4,stroke-width:1px,color:#0b2239
    classDef mart fill:#eef7ea,stroke:#2e7d32,stroke-width:1px,color:#0d2b10
    classDef cache fill:#fff3e0,stroke:#ef6c00,stroke-width:1px,color:#4a2a00
    classDef app fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px,color:#2a1038
    classDef future fill:#e0f2f1,stroke:#00695c,stroke-width:1px,color:#00251a

    CM[(cleansed_market)]:::src

    MV[vw_mart_dashboard_symbol_deviation_bucket]:::mart
    CT[(dash_cache_symbol_deviation_bucket)]:::cache
    META[(dash_cache_refresh_metadata)]:::cache

    SP[Dashboard Start Page<br/>Violin per Symbol]:::app
    DP[Dashboard Detail Page<br/>Selected Symbol Spread]:::app

    F1[(fact_symbol_exchange_close_bucket)]:::future
    F2[(fact_symbol_spread_bucket)]:::future
    D1[(dim_symbol)]:::future
    D2[(dim_exchange)]:::future
    D3[(dim_time_bucket)]:::future

    CM --> MV
    MV --> CT
    CT --> SP
    CT --> DP
    META -. cache freshness .-> SP

    CT --> F2
    CM --> F1
    F1 --> D1
    F1 --> D2
    F1 --> D3
    F2 --> D1
    F2 --> D3
