flowchart TB
    classDef proc fill:#e8f4ff,stroke:#1f78b4,stroke-width:1px,color:#0b2239
    classDef db fill:#eef7ea,stroke:#2e7d32,stroke-width:1px,color:#0d2b10
    classDef ext fill:#fff3e0,stroke:#ef6c00,stroke-width:1px,color:#4a2a00
    classDef q fill:#f3e5f5,stroke:#6a1b9a,stroke-width:1px,color:#2a1038

    subgraph EXT[External]
        EX[(CCXT Pro Exchanges)]
    end
    class EX ext

    subgraph CTRL[Control Plane]
        ORCH[orchestrator_auto_shard.py]
        PROBE[Capability Probe + Profiling]
        SHARD[Shard Planner]
    end
    class ORCH,PROBE,SHARD proc

    subgraph ING[Ingestion Workers]
        W1[Worker 1 ingest_all_exchanges_ws.py]
        W2[Worker 2 ingest_all_exchanges_ws.py]
        WN[Worker N ingest_all_exchanges_ws.py]

        Q1[[Writer Queue]]
        Q2[[Writer Queue]]
        QN[[Writer Queue]]

        PW1[Partition Writer]
        PW2[Partition Writer]
        PWN[Partition Writer]
    end
    class W1,W2,WN,PW1,PW2,PWN proc
    class Q1,Q2,QN q

    subgraph VAULT[VAULT 2.0 Storage]
        PART[(Partition DBs by exchange/date/hour)]
        MAN[(vault_manifest.db)]
    end
    class PART,MAN db

    ORCH --> PROBE
    PROBE --> SHARD
    SHARD --> W1
    SHARD --> W2
    SHARD --> WN

    EX --> W1
    EX --> W2
    EX --> WN

    W1 --> Q1 --> PW1
    W2 --> Q2 --> PW2
    WN --> QN --> PWN

    PW1 --> PART
    PW2 --> PART
    PWN --> PART

    PW1 --> MAN
    PW2 --> MAN
    PWN --> MAN

    ORCH -. restart policy .-> W1
    ORCH -. restart policy .-> W2
    ORCH -. restart policy .-> WN
