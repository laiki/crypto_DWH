erDiagram
    STG_EXPORT_RUN_METADATA ||--o{ STG_MARKET_TICK : exports
    STG_EXPORT_RUN_METADATA ||--o{ STG_CONNECTION_EVENT : exports

    STG_EXPORT_RUN_METADATA {
        string run_id PK
        datetime created_utc
        string vault_root
        string manifest_db
        string layer
        float hours
        float start_relative_from_hour
        bigint window_start_epoch_s
