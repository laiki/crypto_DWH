flowchart LR
    classDef actor fill:#fff3e0,stroke:#ef6c00,stroke-width:1px,color:#4a2a00
    classDef usecase fill:#e8f4ff,stroke:#1f78b4,stroke-width:1px,color:#0b2239
    classDef data fill:#eef7ea,stroke:#2e7d32,stroke-width:1px,color:#0d2b10

    A[Analyst]:::actor
    B[Data Engineer]:::actor

    U1((Export last X hours)):::usecase
    U2((Apply exchange, asset, symbol scope)):::usecase
    U3((Use relative offset windows)):::usecase
    U4((Inspect selected partition count)):::usecase
    U5((Generate staging SQLite snapshot)):::usecase
    U6((Run ad hoc SQL checks)):::usecase
    U7((Prepare input for cleansing and core)):::usecase

    D1[(vault_manifest.db)]:::data
    D2[(vault partitions)]:::data
    D3[(staging_export_*.db)]:::data

    A --> U1
    A --> U2
    A --> U3
    A --> U6
    B --> U4
    B --> U5
    B --> U7

    U1 --> U5
    U2 --> U5
    U3 --> U5
    U4 --> U5
    D1 --> U5
    D2 --> U5

    U5 --> D3
    D3 --> U6
    D3 --> U7
