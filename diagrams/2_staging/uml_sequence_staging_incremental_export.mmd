sequenceDiagram
    autonumber
    actor OP as Operator
    participant EXP as staging_exporter.py
    participant MAN as vault_manifest.db
    participant PART as VAULT partition DBs
    participant OUT as staging_export_*.db

    OP->>EXP: Run with --hours H and --start-relative-from-hour O
    EXP->>MAN: Resolve source max timestamp with scope filters
    MAN-->>EXP: source_max_epoch_s
    EXP->>EXP: Compute window [source_max - O - H, source_max - O]
    EXP->>MAN: Select overlapping partitions for layer and scope
    MAN-->>EXP: partition list

    loop each selected partition
        EXP->>PART: Attach partition DB
        PART-->>EXP: market_ticks and connection_events rows in window
        EXP->>OUT: Insert rows with source provenance columns
    end

    EXP->>OUT: Insert staging_export_run_metadata row
    EXP-->>OP: Print summary and output DB path
