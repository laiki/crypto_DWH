flowchart TD
    subgraph SRC["Source Data"]
        STAGING["Staging Export DBs<br/>(worker-derived history)"]
        CLEAN["Cleansing DB<br/>(reference run window)"]
    end

    subgraph TRAIN["Forecast Training Domain"]
        ORCH["Forecast Training Orchestrator"]
        CUT["Cutoff Resolver<br/>(min cleansing bucket_start_utc)"]
        RES["In-Memory Resampler<br/>(target cadence, e.g. 60s)"]
        FEAT["Feature Engineering"]
        MODELS["Model Trainers<br/>Ridge + HistGradientBoosting"]
        EVAL["Evaluator<br/>(TimeSeriesSplit + Holdout)"]
    end

    subgraph OUT["Artifacts"]
        REGDB["forecasting_registry.db<br/>(run + model metadata + metrics)"]
        MODELFS["Model Filesystem<br/>joblib artifacts"]
    end

    CLEAN --> CUT
    STAGING --> ORCH
    CUT --> ORCH
    ORCH --> RES
    RES --> FEAT
    FEAT --> MODELS
    MODELS --> EVAL
    EVAL --> REGDB
    MODELS --> MODELFS

    NOTE["Design rule:<br/>no persistent resampled training DB"]
    RES -.-> NOTE
