sequenceDiagram
    autonumber

    actor Op as Operator
    participant EX as Exchanges
    participant ORCH as 1_ingestion orchestrator_auto_shard.py
    participant ING as 1_ingestion ingest_all_exchanges_ws.py
    participant PART as VAULT partitions
    participant MAN as VAULT manifest
    participant STG as 2_staging staging_exporter.py
    participant STGDB as Staging DB
    participant CLN as 3_cleansing cleansing_resample.py
    participant CLNDB as Cleansing DB
    participant CORE as 4_core build_core_db.py
    participant COREDB as Core DB
    participant MART as 5_marts build_dashboard_cache.py
    participant FC as 6_forecasting train_staging_models_and_forecasts.py
    participant DASH as dashboard_mvp_app.py

    Op->>ORCH: start ingestion workers
    ORCH->>ING: spawn worker commands with vault-root

    loop streaming runtime
        EX-->>ING: ticker updates
        ING->>PART: append tick/event rows to exchange-hour partition DB
        ING->>MAN: upsert partition and pair metadata
    end

    Op->>STG: export hours window with offset
    STG->>MAN: resolve source max and matching partitions
    STG->>PART: read only overlapping partitions
    STG->>STGDB: materialize staging window DB

    Op->>CLN: run cleansing
    CLN->>STGDB: read market_ticks window
    CLN->>CLNDB: write cleansed bins and metadata

    Op->>CORE: build core
    CORE->>STGDB: read raw staging rows
    CORE->>CLNDB: read cleansed rows
    CORE->>COREDB: write KPI tables and views

    Op->>MART: refresh dashboard cache
    MART->>COREDB: build dash cache tables

    Op->>FC: train forecasting models
    FC->>MAN: select manifest-pruned partitions before cutoff
    FC->>PART: load pair training history
    FC->>CLNDB: load cleansing inference rows
    FC->>COREDB: write model registry and predictions

    Op->>DASH: open dashboard
    DASH->>COREDB: read cache and forecast outputs
